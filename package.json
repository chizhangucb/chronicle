{
  "name": "chronicle",
  "version": "0.1.2",
  "description": "Local-first AI coding session time machine",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "desktop": "npm run build && electron .",
    "standalone": "npm run build && node server/standalone.js",
    "dist:mac": "npm run build && electron-builder --mac --arm64 --x64",
    "reinstall:mac": "pkill -f 'Chronicle.app/Contents/MacOS/Chronicle' || true; npm run build && electron-builder --mac --arm64 && ditto release/mac-arm64/Chronicle.app /Applications/Chronicle.app && open -a /Applications/Chronicle.app",
    "dist:win": "npm run build && electron-builder --win --x64",
    "dist:linux": "npm run build && electron-builder --linux --x64"
  },
  "keywords": [],
  "author": "Chi Zhang",
  "license": "MIT",
  "build": {
    "appId": "com.chizhang.chronicle",
    "productName": "Chronicle",
    "asar": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "server/**",
      "electron/**",
      "hooks/**",
      "package.json"
    ],
    "electronLanguages": [
      "en",
      "zh_CN"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": "dmg",
      "identity": null,
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "format": "ULFO"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-Setup-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development",
      "maintainer": "Chi Zhang <chi.zhang@gokite.ai>",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  },
  "type": "module",
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "diff": "^9.0.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "vite": "^8.1.3"
  },
  "dependencies": {
    "express": "^5.2.1"
  }
}
